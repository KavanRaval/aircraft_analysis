{
  "datasets": [
    {
      "name": "airline_by_year",
      "displayName": "Airline Performance by Year",
      "config": {
        "version": "1.1",
        "source": "SELECT\n  s.Year,\n  s.Reporting_Airline,\n  a.Description AS Airline_Name,\n  COUNT(*) AS TotalFlights,\n  SUM(s.Cancelled) AS CancelledFlights,\n  SUM(s.Diverted) AS DivertedFlights,\n  AVG(s.ArrDelay) AS AverageArrivalDelay,\n  AVG(s.DepDelay) AS AverageDepartureDelay\nFROM aircraft_data.dataset.silver_flight_data s LEFT JOIN aircraft_data.dataset.aircraft_table a ON s.Reporting_Airline = a.Code GROUP BY s.Year, s.Reporting_Airline, a.Description\n",
        "dimensions": [
          {
            "name": "Year",
            "expr": "source.Year"
          },
          {
            "name": "Reporting_Airline",
            "expr": "source.Reporting_Airline"
          },
          {
            "name": "Airline_Name",
            "expr": "source.Airline_Name"
          }
        ],
        "measures": [
          {
            "name": "TotalFlights",
            "expr": "SUM(source.TotalFlights)"
          },
          {
            "name": "CancelledFlights",
            "expr": "SUM(source.CancelledFlights)"
          },
          {
            "name": "DivertedFlights",
            "expr": "SUM(source.DivertedFlights)"
          },
          {
            "name": "AverageArrivalDelay",
            "expr": "AVG(source.AverageArrivalDelay)"
          },
          {
            "name": "AverageDepartureDelay",
            "expr": "AVG(source.AverageDepartureDelay)"
          }
        ]
      }
    }
  ],
